# Database
DATABASE_URL=postgresql://user:password@localhost:5432/dorklib

# Session
SESSION_SECRET=your-secret-here

# GitHub (for live source ingestion - optional, increases API rate limits)
GITHUB_TOKEN=ghp_your_token_here

# Google Custom Search (for live Google dork pattern discovery)
GOOGLE_CSE_API_KEY=
GOOGLE_CSE_ID=

# RSS Feeds (comma-separated URLs)
RSS_FEEDS=
MEDIUM_FEEDS=

# AI Integration (optional - for auto-categorization)
AI_API_KEY=
AI_MODEL=gpt-4o-mini
AI_BASE_URL=https://api.openai.com/v1
